<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>GBTA Join Flow</masterLabel>
    <description>Multi-step membership sign-up flow launched from a Join Now button</description>
    <targets>
        <target>lightningCommunity__Page</target>
        <target>lightningCommunity__Default</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightningCommunity__Default">
            <property
                name="buttonLabel"
                type="String"
                default="Join Now"
                label="Button Label"
            />
            <property
                name="buttonVariant"
                type="String"
                default="primary"
                label="Button Variant"
                datasource="primary,secondary,ghost"
                description="Visual style of the Join Now button"
            />
            <property
                name="checkoutPageApiName"
                type="String"
                label="Checkout Page API Name"
                description="Experience Cloud page API name to navigate to after Proceed to Checkout"
            />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>