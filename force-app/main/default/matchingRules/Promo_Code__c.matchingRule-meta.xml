<?xml version="1.0" encoding="UTF-8"?>
<MatchingRules xmlns="http://soap.sforce.com/2006/04/metadata">
    <matchingRules>
        <fullName>Promo_Code_Code_Currency_Match</fullName>
        <booleanFilter>1 AND 2</booleanFilter>
        <description>Exact match on Code__c AND CurrencyIsoCode. Backs the duplicate rule that enforces composite uniqueness.</description>
        <label>Promo Code: Code + Currency</label>
        <matchingRuleItems>
            <fieldName>Code__c</fieldName>
            <matchingMethod>Exact</matchingMethod>
        </matchingRuleItems>
        <matchingRuleItems>
            <fieldName>CurrencyIsoCode</fieldName>
            <matchingMethod>Exact</matchingMethod>
        </matchingRuleItems>
        <ruleStatus>Active</ruleStatus>
    </matchingRules>
</MatchingRules>
